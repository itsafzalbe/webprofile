# App
APP_NAME=AVZALBEK OS
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development       # development | production

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# MongoDB
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=avzalbek_os

# Redis
# Local:   redis://localhost:6379
# Upstash: rediss://<user>:<pass>@<host>:6379
REDIS_URL=redis://localhost:6379

# JWT
# Generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin credentials — only accessible via hidden terminal commands
ADMIN_USERNAME=avzalbek
ADMIN_PASSWORD=your_strong_password_here

# GitHub
# Generate at: github.com → Settings → Developer settings → Fine-grained tokens
# Required scopes: read:user, public_repo
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=your_github_username

# AI Assistant (optional — skip if not building assistant)
AI_API_KEY=your_anthropic_or_openai_key_here
AI_MODEL=claude-sonnet-4-20250514

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Contact form
MAX_MESSAGE_LENGTH=2000